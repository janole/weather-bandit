{
  "name": "weather-bandit",
  "private": true,
  "version": "0.1.0",
  "description": "Deterministic, LLM-free weather forecasts from Open-Meteo — cross-validated models, ensemble probabilities, and a Markdown + JSON daily outlook.",
  "license": "MIT",
  "author": "Jan Ole Suhr",
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "tsx packages/cli/src/bin.ts",
    "lint": "eslint . --cache --cache-strategy content",
    "lint:fix": "eslint . --cache --cache-strategy content --fix",
    "ok": "pnpm run build && pnpm run typecheck && pnpm run lint:fix && pnpm run test",
    "qa": "pnpm run build && pnpm run typecheck && pnpm run lint && pnpm run test",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^9.39.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^16.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "commander": "^15.0.0"
  }
}